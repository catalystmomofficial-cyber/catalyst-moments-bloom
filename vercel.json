{
  "rewrites": [
    {
      "source": "/rss.xml",
      "destination": "https://moxxceccaftkeuaowctw.supabase.co/functions/v1/serve-rss"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://moxxceccaftkeuaowctw.supabase.co/functions/v1/generate-sitemap"
    }
  ],
  "headers": [
    {
      "source": "/rss.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
